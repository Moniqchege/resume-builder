{
  "compilerOptions": {
    "target": "ES2022",              // or ES2020, ESNext
    "module": "ES2022",              // MUST be ES2020/ES2022/ESNext/node16/node18
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
